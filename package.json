{
  "name": "baton",
  "version": "0.4.0",
  "description": "Git for agent memory — verifiable handoffs between coding agents, on Sui + Walrus + Seal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandatedisrael/Baton.git"
  },
  "homepage": "https://github.com/mandatedisrael/Baton#readme",
  "bugs": {
    "url": "https://github.com/mandatedisrael/Baton/issues"
  },
  "preferGlobal": true,
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md",
    "docs/mcp.md",
    "docs/sponsor-operations.md"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "baton": "./dist/cli/index.js",
    "baton-mcp": "./dist/mcp/index.js",
    "baton-sponsor": "./dist/sponsor/index.js"
  },
  "scripts": {
    "baton": "node src/cli/index.ts",
    "mcp": "node src/mcp/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mysten/seal": "^1.2.1",
    "@mysten/sui": "^2.19.0",
    "@mysten/walrus": "^1.2.1",
    "zod": "^4.4.3"
  }
}
